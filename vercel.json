{
	"version": 2,
	"builds": [
		{ "src": "api/index.ts", "use": "@vercel/node" },
		{
			"src": "package.json",
			"use": "@vercel/static-build",
			"config": { "distDir": "build" }
		}
	],
	"headers": [
		{
			"source": "/(.*)",
			"headers": [
				{ "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" }
			]
		}
	],
	"routes": [
		{ "src": "/api/(.*)", "dest": "api/index.ts" },
		{ "handle": "filesystem" },
		{ "src": "/(.*)", "dest": "/index.html" }
	]
}
